# ========================================
# MARIAM - Variables d'environnement (Production)
# ========================================
# Copiez ce fichier en '.env' et remplacez les valeurs.
# NE JAMAIS COMMITTER LE FICHIER .env AVEC LES VRAIS SECRETS !
#
# Générez des clés aléatoires avec :
#   openssl rand -hex 32

# ----------------------------------------
# BASE DE DONNÉES PostgreSQL
# ----------------------------------------
POSTGRES_USER=mariam
POSTGRES_PASSWORD=CHANGEZ_CE_MOT_DE_PASSE_ALEATOIRE_32_CHARS
POSTGRES_DB=mariam_db

# ----------------------------------------
# FLASK BACKEND
# ----------------------------------------
# Clé secrète pour Flask (sessions, CSRF)
SECRET_KEY=CHANGEZ_CETTE_CLE_SECRETE_ALEATOIRE_64_CHARS

# Clé pour signer les tokens JWT
JWT_SECRET_KEY=CHANGEZ_CETTE_AUTRE_CLE_POUR_JWT_64_CHARS

# Durée de vie du token d'accès (en minutes)
# Recommandé : 30 min pour les postes partagés
JWT_ACCESS_TOKEN_MINUTES=30

# Nom affiché dans les apps d'authentification MFA
# (Google Authenticator, Microsoft Authenticator, etc.)
MFA_ISSUER_NAME=MARIAM

# URL du frontend (pour les emails, CORS, etc.)
# En production, mettez votre domaine
FRONTEND_URL=http://localhost

# ----------------------------------------
# FRONTEND / DÉPLOIEMENT
# ----------------------------------------
# STOCKAGE S3 (Images événements)
# ----------------------------------------
# En production : Scaleway Object Storage (ou tout provider S3-compatible)
# En dev : MinIO est déjà configuré dans docker-compose.yml
#
# Scaleway : https://console.scaleway.com → Object Storage → Créer un bucket
S3_ENDPOINT_URL=https://s3.fr-par.scw.cloud
S3_ACCESS_KEY_ID=CHANGEZ_VOTRE_ACCESS_KEY_SCALEWAY
S3_SECRET_ACCESS_KEY=CHANGEZ_VOTRE_SECRET_KEY_SCALEWAY
S3_BUCKET_NAME=mariam-uploads
S3_REGION=fr-par
# URL publique du bucket (pour servir les images)
# Scaleway : https://<bucket>.s3.<region>.scw.cloud
S3_PUBLIC_URL=https://mariam-uploads.s3.fr-par.scw.cloud

# ----------------------------------------
# REDIS (Upstash)
# ----------------------------------------
# Utilisé pour : blacklist des tokens JWT (logout), rate limiting partagé
# entre workers Gunicorn, cache (jours fériés).
# (rediss://...)
REDIS_URL=CHANGEZ_VOTRE_URL_REDIS_UPSTASH

# ----------------------------------------
# WEBAUTHN / PASSKEYS
# ----------------------------------------
# RP ID = domaine public (sans schéma ni port), Origin = URL complète.
# Sans ces valeurs, l'enregistrement et la connexion par passkey échouent.
WEBAUTHN_RP_ID=CHANGEZ_VOTRE_DOMAINE  # ex. mariam.app
WEBAUTHN_RP_NAME=MARIAM
WEBAUTHN_ORIGIN=CHANGEZ_VOTRE_URL     # ex. https://mariam.app

# ----------------------------------------
# NOTIFICATIONS PUSH (Web Push / VAPID)
# ----------------------------------------
# Générez une paire de clés VAPID avec (ne pas changer après déploiement) :
# npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=CHANGEZ_VOTRE_CLE_PUBLIQUE_VAPID
VAPID_PRIVATE_KEY=CHANGEZ_VOTRE_CLE_PRIVEE_VAPID
VAPID_CONTACT_EMAIL=contact@mariam.app

# ----------------------------------------
# ANALYTICS (Umami)
# ----------------------------------------
# Identifiant du site dans votre instance Umami
UMAMI_WEBSITE_ID=CHANGEZ_VOTRE_UMAMI_WEBSITE_ID

# ----------------------------------------
# Port d'écoute (80 par défaut)
PORT=80

# ----------------------------------------
# MULTI-TENANT (URLs par organisation)
# ----------------------------------------
# Le sous-domaine avant BASE_DOMAIN = slug de l'organisation
# (ex. crous-creteil.mariam.app → org « crous-creteil »).
BASE_DOMAIN=mariam.app
# Organisation par défaut quand le Host ne correspond à aucun sous-domaine
# (apex, domaine inconnu). Vide = 404 dans ce cas.
DEFAULT_ORG_SLUG=
# URL interne du conteneur frontend, d'où le backend récupère le shell HTML
# pour l'injection SEO côté serveur. Défaut : le nom du service compose.
FRONTEND_ORIGIN=http://frontend

# ----------------------------------------
# DÉPLOIEMENT (images GHCR & rollback)
# ----------------------------------------
# Tag d'image à déployer. Laissez 'latest' ou épinglez une version pour
# rollback (ex. MARIAM_TAG=0.15.0). Sert aussi de version affichée par /health.
MARIAM_TAG=latest
# (Optionnel) Surcharger le préfixe des images si le repo change de nom/owner.
# BACKEND_IMAGE=ghcr.io/tezay/mariam-backend
# FRONTEND_IMAGE=ghcr.io/tezay/mariam-frontend

# Réglages Gunicorn (adapter au VPS)
GUNICORN_WORKERS=3
GUNICORN_THREADS=4

# ----------------------------------------
# SUIVI D'ERREURS (Sentry — région EU)
# ----------------------------------------
# Deux projets Sentry (backend Python + frontend React), un DSN chacun.
# Laissez vide pour désactiver.
SENTRY_DSN=                 # DSN du projet backend
FRONTEND_SENTRY_DSN=        # DSN du projet frontend
SENTRY_ENVIRONMENT=production

# ----------------------------------------
# BACKUPS POSTGRES (bucket Scaleway dédié)
# ----------------------------------------
# Bucket S3 SÉPARÉ des médias, avec une clé d'accès dédiée (droits limités au bucket).
# Le service backup y pousse un pg_dump quotidien.
BACKUP_S3_ENDPOINT=https://s3.fr-par.scw.cloud
BACKUP_S3_ACCESS_KEY=CHANGEZ_ACCESS_KEY_BACKUP
BACKUP_S3_SECRET_KEY=CHANGEZ_SECRET_KEY_BACKUP
BACKUP_S3_BUCKET=mariam-backups
# Fréquence (secondes) et rétention (jours)
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=30
